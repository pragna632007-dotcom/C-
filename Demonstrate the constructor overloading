#include <iostream>

class Rectangle {
private:
    int width;
    int height;

public:
    // 1. Default Constructor (No arguments)
    Rectangle() {
        width = 1;
        height = 1;
    }

    // 2. Parameterized Constructor (One argument for a square)
    Rectangle(int side) {
        width = side;
        height = side;
    }

    // 3. Parameterized Constructor (Two arguments for standard rectangle)
    Rectangle(int w, int h) {
        width = w;
        height = h;
    }

    int getArea() {
        return width * height;
    }
};

int main() {
    // Calls the default constructor
    Rectangle rect1; 
    
    // Calls the single-argument constructor
    Rectangle rect2(5); 
    
    
    Rectangle rect3(4, 6); 

    std::cout << "Area 1: " << rect1.getArea() << std::endl; // Output: 1
    std::cout << "Area 2: " << rect2.getArea() << std::endl; // Output: 25
    std::cout << "Area 3: " << rect3.getArea() << std::endl; // Output: 24

    return 0;
}
